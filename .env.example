# 複製此檔為 .env 並填入實際值。.env 請勿提交到 Git。
# Copy this file to .env and fill in real values. Do not commit .env to Git.

# Django 密鑰（正式環境必填，請用 python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 產生）
DJANGO_SECRET_KEY=your-secret-key-here

# 除錯模式：正式環境請設為 False
DJANGO_DEBUG=True

# 允許的 Host（逗號分隔，正式環境請設為實際網域）
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS 允許的來源（正式環境必填，逗號分隔；DEBUG=True 時自動允許全部）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 資料庫設定
DB_NAME=rtsp_vision
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432